# ============================================================================
# BridgesLLM Portal — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://bridges:${POSTGRES_PASSWORD}@localhost:5432/bridgesllm_portal

# ─── Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=generate_a_random_64_char_string
JWT_REFRESH_SECRET=generate_another_random_64_char_string

# ─── Domain & CORS ──────────────────────────────────────────────────────────
PORTAL_DOMAIN=https://your-domain.com
CORS_ORIGIN=https://your-domain.com
VITE_API_URL=https://your-domain.com/api

# ─── Paths ──────────────────────────────────────────────────────────────────
# Root directory for the portal installation
PORTAL_ROOT=/opt/bridgesllm

# Directory for deployed/hosted apps
APPS_ROOT=/var/www/bridgesllm-apps

# OpenClaw installation root (for AI gateway integration)
OPENCLAW_ROOT=/root/.openclaw

# ─── AI Gateway (OpenClaw) ──────────────────────────────────────────────────
# Canonical backend URL consumed by the portal server.
OPENCLAW_API_URL=http://localhost:18789
# Legacy alias kept for older scripts/integrations; safe to mirror OPENCLAW_API_URL.
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your_openclaw_token_here

# ─── Git Configuration ─────────────────────────────────────────────────────
# Email used for git commits in the code editor
GIT_AUTHOR_EMAIL=admin@your-domain.com

# ─── Remote Desktop (optional) ─────────────────────────────────────────────
VNC_PASSWORD=your_vnc_password
GUACAMOLE_USERNAME=admin
GUACAMOLE_PASSWORD=your_guacamole_password

# ─── External APIs (optional) ──────────────────────────────────────────────
# Anthropic API key (for direct AI features, if not using OpenClaw gateway)
# ANTHROPIC_API_KEY=sk-ant-...
