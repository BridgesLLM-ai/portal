# BridgesLLM Portal — Environment Configuration
# Copy this to .env.production and fill in your values.
# The installer generates this automatically.

NODE_ENV=production
PORT=4001

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@127.0.0.1:5432/bridgesllm_portal"

# Authentication (generate with: openssl rand -hex 32)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Paths
PORTAL_ROOT=/opt/bridgesllm/portal
APPS_ROOT=/opt/bridgesllm/apps
UPLOAD_DIR=/opt/bridgesllm/uploads

# CORS — set to your domain after setup
CORS_ORIGIN=http://YOUR_SERVER_IP

# Public IP (auto-detected by installer)
PUBLIC_IP=

# OpenClaw AI Agent
OPENCLAW_API_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# Ollama (local AI)
OLLAMA_API_URL=http://127.0.0.1:11434

# Mail (optional — configured via setup wizard)
# MAIL_DOMAIN=yourdomain.com
# STALWART_URL=http://127.0.0.1:8580
# STALWART_ADMIN_PASS=
# STALWART_SUPPORT_USER=support
# STALWART_SUPPORT_PASS=
# STALWART_NOREPLY_USER=noreply
# STALWART_NOREPLY_PASS=
